{
  "name": "configvault",
  "version": "0.1.0",
  "description": "TypeScript CLI for managing environment configuration files across multiple environments with validation, diff, merge, and AES-256 encryption",
  "type": "module",
  "bin": {
    "configvault": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean --sourcemap",
    "dev": "tsup src/cli.ts --format esm --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "demo": "node dist/cli.js load --input samples/envs/dev.env"
  },
  "keywords": [
    "dotenv",
    "env",
    "config",
    "encryption",
    "aes-256",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "tsup": "^8.0.1",
    "vitest": "^1.2.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "prettier": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
